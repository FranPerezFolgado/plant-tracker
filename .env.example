## Plant Tracker (ZimaOS) environment
## Copy to `.env` and edit values.

## MQTT
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_TOPIC=zigbee2mqtt/#

## InfluxDB (initial setup)
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=adminpassword
INFLUXDB_ORG=plant-tracker
INFLUXDB_BUCKET=sensors
INFLUXDB_ADMIN_TOKEN=changeme-token

## App (uses the same token as admin token by default)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme-token

